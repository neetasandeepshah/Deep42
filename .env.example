# Deep42 environment — copy to .env and fill in values

# ── Dropbox (optional — only needed for portal sources) ─────────────────────
# Create an app at https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:8787/api/auth/dropbox/callback

# ── Server ───────────────────────────────────────────────────────────────────
DEEP42_HOST=127.0.0.1
DEEP42_PORT=8787

# ── Catalog ──────────────────────────────────────────────────────────────────
DEEP42_DB_PATH=deep42_catalog.db

# ── Scan concurrency (raise carefully — Dropbox API throttling risk) ─────────
CATALOG_SCAN_WORKERS=2
